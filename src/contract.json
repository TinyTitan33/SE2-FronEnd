{
  "campaignId": "cmp_complaint_reference",
  "languages": ["en", "fi"],
  "ui": {
    "requiredMark": "*"
  },
  "products": [
    { "id": "toaster", "name": "Toaster" },
    { "id": "kettle", "name": "Kettle" },
    { "id": "coffee_maker", "name": "Coffee maker" }
  ],
  "pages": [
    {
      "id": "page_identity",
      "order": 1,
      "fields": [
        {
          "id": "first_name",
          "type": "text",
          "required": true,
          "ui": { "showRequirementHint": true },
          "order": 1,
          "label": { "en": "First name", "fi": "Etunimi" },
          "helpText": { "en": "Example: Jane", "fi": "Esimerkki: Maija" }
        },
        {
          "id": "last_name",
          "type": "text",
          "required": true,
          "ui": { "showRequirementHint": true },
          "order": 2,
          "label": { "en": "Last name", "fi": "Sukunimi" },
          "helpText": { "en": "Example: Doe", "fi": "Esimerkki: Meikäläinen" }
        },
        {
          "id": "email",
          "type": "email",
          "required": true,
          "ui": { "showRequirementHint": true },
          "order": 3,
          "label": { "en": "Email", "fi": "Sähköposti" },
          "helpText": {
            "en": "We’ll send confirmation (and voucher if approved) to this address.",
            "fi": "Lähetämme vahvistuksen (ja kupongin, jos hyväksytty) tähän osoitteeseen."
          }
        },
        {
          "id": "phone",
          "type": "tel",
          "required": false,
          "order": 4,
          "label": { "en": "Phone", "fi": "Puhelin" }
        },
        {
          "id": "product",
          "type": "dropdown",
          "required": true,
          "ui": { "showRequirementHint": true },
          "order": 5,
          "label": { "en": "Product", "fi": "Tuote" },
          "helpText": { "en": "Select the product .", "fi": "Valitse tuote.." },
          "options": [
            { "value": "toaster", "label": { "en": "Toaster", "fi": "Leivänpaahdin" } },
            { "value": "kettle", "label": { "en": "Kettle", "fi": "Vedenkeitin" } },
            { "value": "coffee_maker", "label": { "en": "Coffee maker", "fi": "Kahvinkeitin" } }
          ]
        },
        {
          "id": "variant_model",
          "type": "text",
          "required": false,
          "order": 6,
          "label": { "en": "Variant / model", "fi": "Malli" },
          "helpText": { "en": "e.g., Model X200", "fi": "esim. Malli X200" }
        }
      ]
    },
    {
      "id": "page_issue_details",
      "order": 2,
      "fields": [
        {
          "id": "topic",
          "type": "dropdown",
          "required": true,
          "ui": { "showRequirementHint": true },
          "order": 1,
          "label": { "en": "Topic", "fi": "Aihe" },
          "options": [
            { "value": "quality", "label": { "en": "Product quality", "fi": "Tuotteen laatu" } }
          ]
        },
        {
          "id": "description",
          "type": "textarea",
          "required": true,
          "ui": { "showRequirementHint": true },
          "order": 2,
          "label": { "en": "Describe what happened", "fi": "Kuvaile mitä tapahtui" },
          "helpText": {
            "en": "Please include key details: what happened and how it affected you.",
            "fi": "Kuvaile mitä tapahtui ja miten se vaikutti sinuun."
          }
        },
        {
          "id": "additional_notes",
          "type": "textarea",
          "required": false,
          "order": 3,
          "label": { "en": "Additional notes", "fi": "Lisätiedot" },
          "validation": { "maxLength": 500 }
        }
      ]
    },
    {
      "id": "page_order_info",
      "order": 3,
      "fields": [
        {
          "id": "order_reference",
          "type": "text",
          "required": false,
          "order": 1,
          "label": { "en": "Order number / receipt reference", "fi": "Tilaus- / kuittinumero" },
          "helpText": { "en": "Optional. Helps prevent duplicate compensation.", "fi": "Valinnainen. Auttaa estämään kaksoiskorvauksia." }
        },
        {
          "id": "store_website",
          "type": "text",
          "required": false,
          "order": 2,
          "label": { "en": "Store / website", "fi": "Kauppa / verkkosivu" },
          "helpText": { "en": "Optional. e.g., Prisma / verkkokauppa", "fi": "Valinnainen. esim. Prisma / verkkokauppa" }
        },
        {
          "id": "price_paid",
          "type": "number",
          "required": false,
          "order": 3,
          "validation": { "min": 0, "step": 0.01 },
          "label": { "en": "Approx. price paid (€)", "fi": "Maksettu hinta (€)" }
        }
      ]
    },
    {
      "id": "page_experience",
      "order": 4,
      "fields": [
        {
          "id": "prevented_use",
          "type": "radio",
          "required": true,
          "ui": { "showRequirementHint": true },
          "order": 1,
          "label": { "en": "Did the issue prevent normal use?", "fi": "Estikö ongelma normaalin käytön?" },
          "options": [
            { "value": "yes", "label": { "en": "Yes", "fi": "Kyllä" } },
            { "value": "no", "label": { "en": "No", "fi": "Ei" } },
            { "value": "not_sure", "label": { "en": "Not sure", "fi": "En ole varma" } }
          ]
        },
        {
          "id": "issues",
          "type": "multiSelect",
          "required": false,
          "order": 2,
          "label": { "en": "Which issues apply?", "fi": "Mitkä ongelmat koskevat?" },
          "options": [
            { "value": "damaged", "label": { "en": "Damaged", "fi": "Vaurioitunut" } },
            { "value": "missing_parts", "label": { "en": "Missing parts", "fi": "Puuttuvia osia" } },
            { "value": "not_working", "label": { "en": "Doesn’t work", "fi": "Ei toimi" } },
            { "value": "unclear_instructions", "label": { "en": "Instructions unclear", "fi": "Ohjeet epäselvät" } }
          ]
        },
        {
          "id": "photos",
          "type": "fileUpload",
          "required": false,
          "order": 4,
          "label": { "en": "Upload photos (jpg/png)", "fi": "Lataa kuvia (jpg/png)" },
          "helpText": { "en": "Add one or more images.", "fi": "Lisää yksi tai useampi kuva." }
        }
      ]
    },
    {
      "id": "page_ratings",
      "order": 5,
      "fields": [
        {
          "id": "product_satisfaction",
          "type": "rating_1_5",
          "required": false,
          "order": 1,
          "label": { "en": "Product satisfaction (1–5)", "fi": "Tuotetyytyväisyys (1–5)" },
          "helpText": {
            "en": "1 = very dissatisfied, 5 = very satisfied",
            "fi": "1 = erittäin tyytymätön, 5 = erittäin tyytyväinen"
          }
        },
        {
          "id": "nps",
          "type": "nps_0_10",
          "required": false,
          "order": 2,
          "label": { "en": "Likelihood to recommend (0–10)", "fi": "Suosittelun todennäköisyys (0–10)" },
          "helpText": {
            "en": "0 = not at all likely, 10 = extremely likely",
            "fi": "0 = ei lainkaan todennäköistä, 10 = erittäin todennäköistä"
          }
        },
        {
          "id": "quantity_affected",
          "type": "number",
          "required": false,
          "order": 3,
          "validation": { "min": 1, "step": 1 },
          "label": { "en": "Quantity affected", "fi": "Vaikutettu määrä" }
        }
      ]
    },
    {
      "id": "page_consent",
      "order": 6,
      "fields": [
        {
          "id": "confirmation",
          "type": "checkbox",
          "required": true,
          "ui": { "showRequirementHint": true },
          "order": 1,
          "label": {
            "en": "I confirm the information is accurate",
            "fi": "Vahvistan tietojen olevan oikein"
          }
        }
      ]
    }
  ]
}